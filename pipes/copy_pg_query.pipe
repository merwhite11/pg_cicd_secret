DESCRIPTION >
    Endpoint to return ids from PostgreSQL table

NODE get_ids
SQL >
%
SELECT id
FROM postgresql(
  {{tb_secret('STG_PG_HOST_PORT', 'ctrl0-postgres')}},
  {{tb_secret('STG_PG_DB')}},
  'conversations_text_id',
  {{tb_secret('STG_PG_USERNAME', 'meredithwhite')}},
  {{tb_secret('STG_PG_PASSWORD', 'mw_password')}}
)


TYPE COPY
TARGET_DATASOURCE copy_pg_target
